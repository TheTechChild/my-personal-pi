{
  "mcpServers": {
    "unraid-docker": {
      "command": "uvx",
      "args": [
        "--from",
        "mcp-server-docker",
        "python",
        "/home/clayton/projects/my-personal-pi/mcp-wrappers/unraid-docker-wrapper.py"
      ],
      "env": {
        "DOCKER_HOST": "ssh://root@192.168.1.152"
      }
    },
    "unraid": {
      "command": "uvx",
      "args": ["--from", "git+https://github.com/TheTechChild/unraid-mcp", "unraid-mcp"],
      "env": {
        "UNRAID_API_URL": "http://192.168.1.152/graphql",
        "UNRAID_API_KEY": "${UNRAID_API_KEY}",
        "UNRAID_VERIFY_SSL": "false",
        "UNRAID_MCP_TRANSPORT": "stdio"
      }
    },
    "filesystem-example": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/home/clayton/projects"]
    },
    "http-example": {
      "url": "https://example.com/mcp",
      "bearerToken": "${EXAMPLE_MCP_TOKEN}",
      "timeoutMs": 60000
    }
  }
}
